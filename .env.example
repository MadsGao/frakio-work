# Optional overrides. Frakio Work stores local state under ~/.frakio-work by default.
PORT=8787
FRAKIO_WORK_HOME=
HERMES_HOME=
HERMES_AGENT_SOURCE=
FRAKIO_WORK_ALLOWED_ORIGINS=
HERMES_GEMINI_CLIENT_ID=
HERMES_GEMINI_CLIENT_SECRET=

# Anonymous telemetry remains disabled until the user explicitly opts in.
FRAKIO_WORK_UMAMI_HOST=https://data.madsgogo.com
FRAKIO_WORK_UMAMI_WEBSITE_ID=
